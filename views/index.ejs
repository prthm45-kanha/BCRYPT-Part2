<!DOCTYPE html>
<html lang="en">    
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="bg-zinc-900 w-full h-screen text-white p-10">
        <h3 class="text-3xl font-semibold mb-3">Create User</h3>
        <form action="/create" method="post">
            <input class="bg-transparent outline-none border-2 border-zinc-700 rounded-md px-3 py-2" type="text" placeholder="Enter username" name="username"/>
             <input class="bg-transparent outline-none border-2 border-zinc-700 rounded-md px-3 py-2" type="email" placeholder="Enter email" name="email"/>
              <input class="bg-transparent outline-none border-2 border-zinc-700 rounded-md px-3 py-2" type="password" placeholder="Enter password" name="password"/>
               <input class="bg-transparent outline-none border-2 border-zinc-700 rounded-md px-3 py-2" type="number" placeholder="Enter Age" name="age"/>
               <input class="px-3 py-2 bg-blue-600 rounded-md font-semibold" type="submit" value="Create User"/>
        </form>
    </div>
</body>
</html>